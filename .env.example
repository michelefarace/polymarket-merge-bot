# OBBLIGATORIO: la private key del tuo wallet Polygon
PRIVATE_KEY=0x...

# Modalita: true = simulazione, false = trading reale
PAPER_TRADING=true

# Capitale iniziale in USDC
INITIAL_CAPITAL_USDC=1000

# Soglia merge: combined cost deve essere < questo valore
MERGE_THRESHOLD=0.97

# Range prezzi OTM
MIN_OTM_PRICE=0.03
MAX_OTM_PRICE=0.15

# Limiti di rischio
MAX_EXPOSURE_PER_MARKET=4000
MAX_TOTAL_EXPOSURE=50000
MAX_DAILY_LOSS=5000
CIRCUIT_BREAKER_LOSS=10000

# Log level
LOG_LEVEL=info
